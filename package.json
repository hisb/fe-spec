{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "author": "yaling.cai",
  "license": "ISC",
  "scripts": {
    "prepublish": "npx only-allow pnpm",
    "prepare": "husky",
    "init": "pnpm install",
    "clean": "lerna clean && rm -rf node_modules",
    "test": "lerna run test",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "deploy": "bash deploy.sh",
    "publish": "lerna run publish",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@vue/server-renderer": "^3.5.39",
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "@vuepress/theme-default": "2.0.0-rc.90",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "sass": "^1.101.0",
    "vite": "^8.0.11",
    "vue": "^3.5.39",
    "vuepress": "2.0.0-rc.30"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
